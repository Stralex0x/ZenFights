# Ignore everything in the root directory
/*

# Explicitly re-include the files and folders we want
!/pom.xml
!/README.md
!/.gitignore
!/src/
!/release_builds/

# Optional: Ignore specific build artifacts inside your folders
# (in case you don't want local 'target' folders or IDE configs to sneak in)
target/
.idea/
.vscode/
*.iml